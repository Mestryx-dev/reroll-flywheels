{
  "name": "flywheels-calc",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"API_PORT=4783 pnpm dev:web\" \"PORT=4783 pnpm dev:api\"",
    "dev:web": "vite",
    "dev:api": "PORT=4783 tsx watch server/index.ts",
    "build": "tsc -b && vite build && pnpm build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "preview": "vite preview",
    "sync-data": "tsx scripts/sync-from-sheet.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "better-sqlite3": "^12.4.1",
    "framer-motion": "^12.23.12",
    "hono": "^4.10.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.5",
    "typescript": "~5.8.3",
    "vite": "^7.1.2"
  }
}
